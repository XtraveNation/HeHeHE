# ================== Rick-o Configuration ==================
# Rick-o - Chaotic Genius Coding Agent (Rick & Morty Edition)

# === OpenRouter (Recommended - One key for 100+ models) ===
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# === Other Major Providers ===
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GROK_API_KEY=xai-your-grok-key-here
GROQ_API_KEY=gsk-your-groq-key-here
GEMINI_API_KEY=your-gemini-key-here
MISTRAL_API_KEY=your-mistral-key-here
DEEPSEEK_API_KEY=your-deepseek-key-here

# === Local Models ===
OLLAMA_HOST=http://host.docker.internal:11434

# === Rick-o Default Settings ===
RICKO_PORT=9000
DEFAULT_PROVIDER=openrouter
DEFAULT_MODEL=openrouter/anthropic/claude-3.7-sonnet

# === Admin Dashboard (Change these immediately!) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-immediately-2026!

# === Data Persistence ===
DATA_DIR=./data
